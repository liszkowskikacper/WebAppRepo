// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Wpis {
  id           Int       @id @default(autoincrement())
  idKategorii  Int
  idKomentarza Int
  Kategoria    Kategoria @relation(fields: [idKategorii], references: [id])
  Komentarz    Komentarz @relation(fields: [idKomentarza], references: [id])
  name         String
  content      String    @db.Text
  author       String
}
model Kategoria {
  id   Int    @id @default(autoincrement())
  name string
  Wpis Wpis[]
}
model Komentarz {
  id      Int    @id @default(autoincrement())
  content String @db.Text
  Wpis    Wpis[]
}
